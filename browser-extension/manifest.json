{
  "manifest_version": 3,
  "name": "Vertex AI - Whole Web Assistant",
  "short_name": "Vertex AI",
  "version": "1.0.0",
  "description": "Use Vertex AI on any webpage with page-aware chat, summaries, browser actions, notes, and read-aloud tools.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "tts"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "externally_connectable": {
    "matches": [
      "https://vertexai-five.vercel.app/*",
      "http://127.0.0.1/*",
      "http://localhost/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_title": "Open Vertex AI",
    "default_popup": "popup.html",
    "default_icon": "icons/icon-128.png"
  },
  "options_page": "options.html",
  "commands": {
    "toggle-vertex-panel": {
      "suggested_key": {
        "default": "Alt+V",
        "mac": "Alt+V"
      },
      "description": "Open or close the Vertex floating assistant"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
